---
interface Props {
  variant?: "tip" | "warning";
}

const { variant = "tip" } = Astro.props;
const isTip = variant === "tip";
---

<div class:list={["callout", `callout-${variant}`]}>
  <div class="callout-icon" aria-hidden="true">
    {isTip ? (
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <circle cx="9" cy="9" r="7.5" stroke="currentColor" stroke-width="1.2" />
        <path d="M9 8v4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
        <circle cx="9" cy="5.75" r="0.75" fill="currentColor" />
      </svg>
    ) : (
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M9 2l7.5 13H1.5L9 2z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round" />
        <path d="M9 7.5v3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
        <circle cx="9" cy="12.75" r="0.75" fill="currentColor" />
      </svg>
    )}
  </div>
  <div class="callout-content">
    <slot />
  </div>
</div>

<style>
  .callout {
    display: flex;
    gap: 12px;
    padding: 14px 16px;
    border-radius: var(--radius);
    margin: 12px 0;
    border-left: 2px solid;
  }

  .callout-tip {
    border-color: var(--accent);
    background: rgba(0, 229, 255, 0.05);
    color: var(--text);
  }

  .callout-tip .callout-icon {
    color: var(--accent);
  }

  .callout-warning {
    border-color: var(--accent3);
    background: rgba(245, 158, 11, 0.05);
    color: var(--text);
  }

  .callout-warning .callout-icon {
    color: var(--accent3);
  }

  .callout-icon {
    flex-shrink: 0;
    margin-top: 1px;
  }

  .callout-content {
    font-size: 13px;
    line-height: 1.6;
  }

  .callout-content :global(p) {
    margin: 0;
  }

  .callout-content :global(strong) {
    font-weight: 600;
  }
</style>
