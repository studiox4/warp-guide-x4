---
interface Props {
  num: string;
  title: string;
  badge: "essential" | "power" | "workflow" | "advanced";
  id: string;
}

const { num, title, badge, id } = Astro.props;

const badgeLabels: Record<string, string> = {
  essential: "Essential",
  power: "Power",
  workflow: "Workflow",
  advanced: "Advanced",
};
---

<section class="section-card" id={id} data-section>
  <button class="section-header" aria-expanded="false" aria-controls={`${id}-body`}>
    <span class="section-num">{num}</span>
    <span class="section-title">{title}</span>
    <span class={`section-badge badge-${badge}`}>{badgeLabels[badge]}</span>
    <svg
      class="section-chevron"
      width="20"
      height="20"
      viewBox="0 0 20 20"
      fill="none"
      aria-hidden="true"
    >
      <path d="M7 4l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </button>
  <div class="section-body" id={`${id}-body`} hidden>
    <div class="section-content">
      <slot />
    </div>
    <button class="mark-complete-btn" data-complete-btn>
      Mark complete
    </button>
  </div>
</section>

<style>
  .section-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color var(--transition);
  }

  .section-card:hover {
    border-color: var(--muted);
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
    padding: 16px 20px;
    background: none;
    border: none;
    color: var(--text);
    cursor: pointer;
    text-align: left;
    font-family: var(--font-body);
    font-size: 14px;
  }

  .section-header:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: -2px;
    border-radius: var(--radius);
  }

  .section-num {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 1.1rem;
    color: var(--accent);
    min-width: 28px;
  }

  .section-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1rem;
    flex: 1;
  }

  .section-badge {
    font-size: 11px;
    font-weight: 500;
    padding: 2px 10px;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .badge-essential {
    background: rgba(239, 68, 68, 0.12);
    color: var(--red);
  }

  .badge-power {
    background: rgba(124, 58, 237, 0.12);
    color: var(--accent2);
  }

  .badge-workflow {
    background: rgba(0, 229, 255, 0.12);
    color: var(--accent);
  }

  .badge-advanced {
    background: rgba(245, 158, 11, 0.12);
    color: var(--accent3);
  }

  .section-chevron {
    color: var(--muted);
    transition: transform var(--transition);
    flex-shrink: 0;
  }

  .section-header[aria-expanded="true"] .section-chevron {
    transform: rotate(90deg);
  }

  .section-body {
    padding: 0 20px 20px;
  }

  .section-body[hidden] {
    display: none;
  }

  .section-content {
    padding-top: 4px;
    border-top: 1px solid var(--border);
    padding-top: 16px;
  }

  .mark-complete-btn {
    display: block;
    margin-top: 24px;
    padding: 8px 20px;
    background: none;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--muted);
    font-family: var(--font-body);
    font-size: 12px;
    cursor: pointer;
    transition:
      color var(--transition),
      border-color var(--transition);
  }

  .mark-complete-btn:hover {
    color: var(--green);
    border-color: var(--green);
  }

  .mark-complete-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .mark-complete-btn.completed {
    color: var(--green);
    border-color: var(--green);
  }

  @media (max-width: 700px) {
    .section-header {
      padding: 14px 16px;
      gap: 8px;
    }

    .section-num {
      font-size: 1rem;
      min-width: 24px;
    }

    .section-title {
      font-size: 0.85rem;
    }

    .section-badge {
      font-size: 10px;
      padding: 1px 8px;
    }

    .section-body {
      padding: 0 16px 16px;
    }

    .mark-complete-btn {
      padding: 10px 20px;
      min-height: 44px;
    }
  }
</style>
