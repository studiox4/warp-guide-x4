---
interface Props {
  items: string[];
}

const { items } = Astro.props;
---

<ul class="checklist" data-checklist>
  {items.map((item) => (
    <li class="checklist-item" data-checklist-item>
      <span class="checklist-box" aria-hidden="true">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
          <path
            class="check-mark"
            d="M2.5 6l2.5 2.5 4.5-5"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </span>
      <span class="checklist-label">{item}</span>
    </li>
  ))}
</ul>

<style>
  .checklist {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin: 12px 0;
  }

  .checklist-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 6px 0;
    cursor: pointer;
    user-select: none;
  }

  .checklist-box {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border: 1.5px solid var(--border);
    border-radius: 4px;
    flex-shrink: 0;
    margin-top: 1px;
    color: transparent;
    transition:
      border-color var(--transition),
      background var(--transition),
      color var(--transition);
  }

  .check-mark {
    opacity: 0;
    transition: opacity var(--transition);
  }

  .checklist-item.checked .checklist-box {
    border-color: var(--green);
    background: rgba(34, 197, 94, 0.12);
    color: var(--green);
  }

  .checklist-item.checked .check-mark {
    opacity: 1;
  }

  .checklist-label {
    font-size: 13px;
    line-height: 1.5;
    color: var(--text);
    transition:
      color var(--transition),
      text-decoration var(--transition);
  }

  .checklist-item.checked .checklist-label {
    color: var(--muted);
    text-decoration: line-through;
  }

  @media (max-width: 700px) {
    .checklist-item {
      padding: 8px 0;
      min-height: 44px;
    }
  }
</style>
